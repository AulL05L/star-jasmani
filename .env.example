APP_NAME="Star Jasmani"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------
# LOG — Gunakan 'error' di production (bukan 'debug')
# ---------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------
# DATABASE — Isi sesuai server production
# ---------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=star_jasmani
DB_USERNAME=star_jasmani_user
DB_PASSWORD=

# ---------------------------------------------------------
# SESSION & KEAMANAN
# ---------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ---------------------------------------------------------
# EMAIL — Ganti dengan konfigurasi email production
# ---------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------
# ADMIN CREDENTIALS — Used only by AdminSeeder (first run)
# ---------------------------------------------------------
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
